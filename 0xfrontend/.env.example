# Public chain, contract, explorer, and subgraph values live in lib/publicConfig.ts.
# Only secrets and optional keeper runtime controls belong in environment files.

# Required only when the prediction keeper sends transactions.
PREDICTION_SETTLER_PRIVATE_KEY=

# Optional prediction keeper controls.
AUTO_SETTLE_INTERVAL_MS=60000
AUTO_SETTLE_LOOKBACK=720
AUTO_SETTLE_SCAN_RECENT_ROUNDS=24
AUTO_CANCEL_STALE=true
