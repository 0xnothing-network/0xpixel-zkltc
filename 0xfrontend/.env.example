# -----------------------------------------------------------------------------
# 0xPixel frontend — environment variables
# Copy this file to `.env.local` and fill in the real values before running
# `npm run dev` or deploying to Vercel.
# -----------------------------------------------------------------------------

# LitVM (LiteForge) JSON-RPC endpoint used by the read-only public client.
NEXT_PUBLIC_LITVM_RPC_URL=https://liteforge.rpc.caldera.xyz/infra-partner-http
# Optional LiteForge explorer base URL used by address, token, and transaction links.
NEXT_PUBLIC_LITVM_EXPLORER_URL=https://liteforge.explorer.caldera.xyz

# Testnet contracts
NEXT_PUBLIC_PIXEL_NFT_ADDRESS=0x33A32b9b2BEe864f9e42BFa39cA7BDC72f655988
NEXT_PUBLIC_PIXEL_MARKETPLACE_ADDRESS=0x13337cadA78d53C90E3c0EcE44C17c467C1a86F4
NEXT_PUBLIC_PIXEL_START_BLOCK=24867130
NEXT_PUBLIC_MARKETPLACE_START_BLOCK=24867505
NEXT_PUBLIC_NUSD_ADDRESS=0xF2d0fd65d9f62D57255AF6350f807E6c11A4CFdb
NEXT_PUBLIC_DEX_ADDRESS=0x873cb0402F0e74Db66663255e6B3535ca134C818
NEXT_PUBLIC_REWARD_MANAGER_ADDRESS=0xCEBbeE6CeAe309E647Be85600dA455C7B15C0de9
NEXT_PUBLIC_FACTORY_ADDRESS=0x93F9d4cF10cB785B47BFaD64ecccEA4D66C73508
# Optional: first block of the Prediction deployment, used to load wallet bet history faster.
NEXT_PUBLIC_PREDICTION_START_BLOCK=24937136
# Optional local keeper wallet for `npm run prediction:settle`.
# Never commit a real private key.
PREDICTION_SETTLER_PRIVATE_KEY=
AUTO_SETTLE_INTERVAL_MS=60000
AUTO_SETTLE_LOOKBACK=720
AUTO_SETTLE_SCAN_RECENT_ROUNDS=24
AUTO_CANCEL_STALE=true
# Optional: first block of the DEX deployment, used to count total Swap History tx.
NEXT_PUBLIC_DEX_START_BLOCK=24869425
# Optional explicit deployment block used to recover immutable initial pool prices.
NEXT_PUBLIC_DEX_DEPLOYMENT_BLOCK=24869425

# Public Goldsky subgraph endpoint for 0xPIXEL gallery + marketplace API routes.
NEXT_PUBLIC_MARKETPLACE_SUBGRAPH_URL=https://api.goldsky.com/api/public/project_cmr0mev6548fr01xtd92rc135/subgraphs/marketplace/1.0.1/gn
NEXT_PUBLIC_SUBGRAPH_URL=https://api.goldsky.com/api/public/project_cmqmpust19i8v01t595z8hpq4/subgraphs/zeroxdex/1.0.6/gn
