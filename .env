# =====================================================================
# 0xPixel on LitVM — environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =====================================================================

# Private key of the deployer wallet (NEVER commit a real key).
# Use a throwaway test key while developing locally. For production,
# load from a keystore (cast wallet import) or a hardware signer.
PRIVATE_KEY=

# LitVM LiteForge testnet RPC (default; override only if using a proxy).
LITVM_RPC_URL=https://liteforge.rpc.caldera.xyz/http

# Optional — Caldera explorer API key (used for `forge verify-contract`).
# Leave blank if you only deploy and do not verify on-chain.
LITVM_EXPLORER_API_KEY=

# Optional — mainnet RPC placeholder for future use.
LITVM_MAINNET_RPC_URL=
