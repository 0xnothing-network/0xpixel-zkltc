{
  "name": "zeroxdex-subgraph",
  "version": "1.0.0",
  "description": "ZeroXDex subgraph for LiteForge",
  "scripts": {
    "codegen": "graph codegen",
    "build": "graph build",
    "deploy": "goldsky subgraph deploy zeroxdex/1.0.6 --path .",
