# -----------------------------------------------------------------------------
# 0xPixel frontend — environment variables
# Copy this file to `.env.local` and fill in the real values before running
# `npm run dev` or deploying to Vercel.
# -----------------------------------------------------------------------------

# WalletConnect Cloud project ID — used by RainbowKit/wagmi to enable
# WalletConnect v2 transport for mobile wallets. Get one for free at
# https://cloud.walletconnect.com/ and replace the placeholder below.
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=replace-me-with-your-walletconnect-project-id

# LitVM (LiteForge) JSON-RPC endpoint used by the read-only public client.
NEXT_PUBLIC_LITVM_RPC_URL=https://liteforge.rpc.caldera.xyz/http
