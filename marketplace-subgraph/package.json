{
  "name": "marketplace-subgraph",
  "version": "1.0.0",
  "description": "0xPIXEL marketplace subgraph for LiteForge",
  "scripts": {
    "codegen": "graph codegen",
    "build": "graph build",
    "deploy": "npx goldsky subgraph deploy marketplace/1.0.1 --path .",
